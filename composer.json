{
  "name": "flowpack/query-object-builder",
  "description": "A builder for query object expressions for fully types database syntax (MySQL, MariaDB, PostgreSQL)",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^2.1",
    "pestphp/pest": "^4.0",
    "imsuperlative/phpstan-pest": "^0.5.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "autoload": {
    "psr-4": {
      "Flowpack\\QueryObjectBuilder\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Flowpack\\QueryObjectBuilder\\Test\\": "tests/"
    }
  }
}
