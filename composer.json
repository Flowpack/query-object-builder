{
  "name": "flowpack/query-object-builder",
  "description": "A fluent, immutable, fully-typed SQL query builder for PHP (PostgreSQL, with more dialects planned).",
  "type": "library",
  "keywords": [
    "sql",
    "query-builder",
    "postgresql",
    "postgres",
    "database",
    "immutable",
    "json"
  ],
  "homepage": "https://github.com/Flowpack/query-object-builder",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Christopher Hlubek",
      "email": "christopher.hlubek@networkteam.com"
    }
  ],
  "support": {
    "issues": "https://github.com/Flowpack/query-object-builder/issues",
    "source": "https://github.com/Flowpack/query-object-builder"
  },
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^2.1",
    "pestphp/pest": "^4.0",
    "imsuperlative/phpstan-pest": "^0.5.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "autoload": {
    "psr-4": {
      "Flowpack\\QueryObjectBuilder\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Flowpack\\QueryObjectBuilder\\Test\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "analyse": "phpstan analyse"
  }
}
